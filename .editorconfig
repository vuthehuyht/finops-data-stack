# EditorConfig helps developers define and maintain consistent
# coding styles between different editors and IDEs.
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

# Python (Adhere to PEP 8 and Ruff config in pyproject.toml)
[*.py]
indent_size = 4
max_line_length = 88

# dbt / SQL (Typically use 2-space indentation for nested SQL statements)
[*.sql]
indent_size = 2

# YAML configuration (Dagster config, dbt schema/properties, GitHub Actions)
[*.{yaml,yml}]
indent_size = 2

# JSON configuration
[*.json]
indent_size = 2

# TOML configuration (pyproject.toml, uv.lock)
[*.toml]
indent_size = 4

# Markdown configuration (preserve trailing whitespace for markdown line breaks)
[*.md]
indent_size = 2
trim_trailing_whitespace = false

# Terraform configuration
[*.tf]
indent_size = 2

# Shell scripts
[*.sh]
indent_size = 2
