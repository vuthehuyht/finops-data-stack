-- Recreate MART table: FCT_ML_FORECAST_RESULTS
-- Populated by Dagster (src/dagster/inference_job.py), NOT a dbt SQL
-- transform — forecast values come from calling the SageMaker endpoint,
-- not from a SELECT over ingested tables.
CREATE TABLE IF NOT EXISTS "{{ schema_name_mart }}"."FCT_ML_FORECAST_RESULTS" (
  TICKER VARCHAR(256),
  TRADING_DATE DATE,
  PREDICTED_RETURN NUMERIC(18, 6),
  MODEL_VERSION VARCHAR(256),
  DATACORE_CREATE_DATETIME TIMESTAMP,
  DATACORE_CREATE_PROGRAM VARCHAR(256),
  DATACORE_CREATE_BY VARCHAR(256),
  DATACORE_UPDATE_DATETIME TIMESTAMP,
  DATACORE_UPDATE_PROGRAM VARCHAR(256),
  DATACORE_UPDATE_BY VARCHAR(256),
  BATCH_DATE DATE
);
